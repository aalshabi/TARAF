generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  phone     String
  service   String
  notes     String   @default("")
  source    String
  status    String   @default("new")
  priority  String   @default("normal")
  team      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Additive fields for the "مستشار ترف" chat flow. Safe for non-chat leads
  // because they all default to empty / null and existing code ignores them.
  sessionId      String @default("") // chat session ID for upsert
  classification String @default("") // hot | warm | cold (only set for chat leads)
  city           String @default("")
  nationality    String @default("")
  budget         String @default("")
  urgency        String @default("") // immediate | soon | flexible
  transcript     String @default("") // JSON-stringified message history

  followUps FollowUp[]

  @@index([sessionId])
  @@index([source])
}

model FollowUp {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  note      String
  type      String
  createdAt DateTime @default(now())
}

model Order {
  id           String   @id @default(cuid())
  orderNumber  String   @unique
  status       String   @default("new")

  customerName    String
  nationalId      String
  phone           String
  email           String   @default("")
  city            String   @default("")
  region          String   @default("")
  nationalAddress String   @default("")

  profession      String
  nationality     String
  gender          String   @default("")
  ageFrom         Int?
  ageTo           Int?
  expectedSalary  Int?
  experienceYears Int?
  language        String   @default("")
  contractMonths  Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments OrderAttachment[]
  events      OrderStatusEvent[]

  @@index([nationalId])
}

model OrderAttachment {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  kind      String
  label     String
  status    String   @default("uploaded")
  url       String   @default("")
  createdAt DateTime @default(now())

  @@index([orderId])
}

model OrderStatusEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String
  note      String   @default("")
  createdAt DateTime @default(now())

  @@index([orderId])
}
